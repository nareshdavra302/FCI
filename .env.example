# Database
DATABASE_URL=postgresql://fci:fci@localhost:5432/fci

# API
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LLM (optional — defaults to rule-engine-only mock mode)
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=

# Planner
PLANNER_WINDOW_MINUTES=5

# Mock services
FCI_INGEST_URL=http://localhost:8000/api/v1/failures

# Frontend
VITE_API_URL=http://localhost:8000

# Simulator
SERVICE_A_URL=http://localhost:8001
SERVICE_B_URL=http://localhost:8002
SERVICE_C_URL=http://localhost:8003
SIMULATOR_INTERVAL=10
